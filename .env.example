# =============================================================================
# CRMForge — Environment Variables
# Copy to .env:  cp .env.example .env
# =============================================================================

# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) ---
# docker compose up postgres -d  OR  npm run docker:infra
DATABASE_URL=postgresql://crmforge:crmforge@localhost:5432/crmforge

# --- Redis ---
# Used for: cache, JWT blacklist, BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Google OAuth ---
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# --- SendGrid (email verification + notifications) ---
# https://app.sendgrid.com/ → Settings → API Keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@crmforge.local
# true = log emails to console instead of SendGrid (local dev without API key)
MAIL_MOCK=true

# --- Encryption (amoCRM tokens at rest) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- amoCRM ---
AMOCRM_MOCK=true
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=http://localhost:3000/api/integrations/amocrm/oauth/callback

# --- Observability (Pino → Loki → Grafana) ---
# Full stack: docker compose up -d
LOKI_URL=http://localhost:3100
# false = logs only to stdout (no Loki transport)
LOKI_ENABLED=false

# --- Grafana (docker only, no env needed in Nest) ---
# UI: http://localhost:3001  (admin / admin)
